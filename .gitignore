# ============================================================================
# Keycloak Migration Tool — .gitignore
# ============================================================================

# Claude Code local settings (CRITICAL - NEVER commit)
.claude/
.claude-ver
.claude-init-attempted

# Generated one-shot profiles (migrate_oneshot writes these into profiles/ per run)
/profiles/oneshot-*

# Operator handover doc — lives beside the tool but must NEVER be committed or released
# (release.yml copies root files by explicit name only, so it also never ships; this is belt+braces)
/HANDOVER.md

# Session handoff note — local working doc, never committed
/SESSION_HANDOFF.md

# Environment variables & secrets
.env
.env.*
*.env
.env.local

# Operator-supplied image config (licensed/internal registry refs) — keep .example
config/images.conf
*.local.conf

# Credentials & keys
*_key
*_key.*
*_secret
*_secret.*
credentials.json
*.pem
*.key
*.crt
*.p12
*.jks
*.keystore

# Password managers
pass/
.password-store/

# API tokens
.token
*.token
api_key.txt

# Database credentials
.pgpass
.my.cnf
.msql_history
.psql_history

# ============================================================================
# Migration-Specific
# ============================================================================

# Work directories
migration_workspace/
work/
dist/
tmp/
temp/
scratch/

# State files
.migration_state
.preflight_passed
*.state
*.checkpoint

# Backup files
*.dump
*.sql
*.backup
*.bak
backup_*/
backups/

# Logs
*.log
*.jsonl
logs/
audit/

# Discovery outputs
discovery_*/
discovered_*.yaml

# Test outputs
test_lab/
.test_artifacts/

# ============================================================================
# General
# ============================================================================

# OS artifacts
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# IDE
.vscode/
.idea/
*.iml

# Temporary files
*.tmp
*.temp

# Archives
*.tar.gz
*.zip
*.tgz

# Node (if using any JS tools)
node_modules/
package-lock.json

# Python (if using any Python tools)
__pycache__/
*.pyc
*.pyo
.venv/
venv/

# ============================================================================
# Keep these files (exceptions)
# ============================================================================
!profiles/*.yaml
!tests/*.sh
!scripts/**/*.sh

# DOCX-документы поставки (на ревью, не коммитим)
handover_docx/
