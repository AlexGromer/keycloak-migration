# Example environment file for migrate_oneshot.sh --env-file
#
#   cp config/kc-migration.env.example /etc/kc-migration.env
#   chmod 600 /etc/kc-migration.env        # REQUIRED — it holds a database password
#   scripts/migrate_oneshot.sh --env-file /etc/kc-migration.env --go
#
# Everything below is optional except PROFILE_DB_PASSWORD (for a live run). Anything you leave out
# keeps its default. Command-line flags override this file.

# ---------------------------------------------------------------------------
# Database — where Keycloak's data actually lives. This is what gets migrated.
# ---------------------------------------------------------------------------
KC_DB_HOST=127.0.0.1
KC_DB_PORT=5432
KC_DB_NAME=keycloak
KC_DB_USER=keycloak

# The password. This file exists so that this line does not have to be in your shell history or in
# the process table. Keep the file mode at 0600 — the tool refuses to read it otherwise.
PROFILE_DB_PASSWORD=change-me

# ---------------------------------------------------------------------------
# Versions
# ---------------------------------------------------------------------------
# Target MAJOR version: 25 or 26. The hop chain is derived from it:
#   26 -> 16.1.1 -> 24.0.5 -> 26.6.3
#   25 -> 16.1.1 -> 25.0.6
KC_TARGET=26

# The version you are on now. Only a starting hint: the tool reads the REAL version out of the
# database (MIGRATION_MODEL) and skips hops the database has already passed (ADR-008).
KC_CURRENT=16.1.1

# ---------------------------------------------------------------------------
# Images — three ways to get them. Pick ONE.
# ---------------------------------------------------------------------------
# Which OS the sovereign images are built on: astra | redos
KC_OS=astra

# HOW the per-hop images are obtained:
#   pull       — from a registry (yours or ours)
#   bundle     — from an offline tar.xz (air-gap). Set KC_BUNDLE below.
#   preloaded  — they are ALREADY in the local container runtime; use them as they are
KC_SOURCE=pull

# (A) Registry, OUR naming convention: <namespace>:<os>-<version>
#     e.g. registry.corp.local/keycloak/kc:astra-26.6.3
KC_IMAGE_NS=ghcr.io/alexgromer/keycloak-migration

# (B) Registry, YOUR naming convention. Overrides KC_IMAGE_NS entirely.
#     Use this when your registry already holds Keycloak images under names of your own — the tool
#     should adapt to your estate, not make you re-tag it. {version} is replaced per hop.
# KC_IMAGE_REF_TEMPLATE=registry.corp.local/keycloak:{version}

# (C) Air-gap bundle (only with KC_SOURCE=bundle)
# KC_BUNDLE=/opt/dist/kc-astra-bundle.tar.xz

# Container network for the migrating container. Default 'host' — needed when the database is on
# the host itself. Set a user-defined bridge if your database is in one.
# KC_NETWORK=kc-net

# ---------------------------------------------------------------------------
# Safety and behaviour
# ---------------------------------------------------------------------------
# Where backups, logs and state go. Point it at a roomy filesystem: one backup is taken before
# EACH hop and they are all kept. The preflight measures what they will need.
# A work dir you supply is NEVER deleted by the tool.
# (pass as --work-dir; there is no env equivalent, so that a typo cannot silently relocate it)

# Create the indexes Keycloak SKIPS on tables above ~300k rows. Without this the migration succeeds
# with indexes missing and the database is quietly slow afterwards. Applied CONCURRENTLY.
# PROFILE_APPLY_SKIPPED_INDEXES=true

# PROVE each backup restores (into a scratch database) instead of just checking that the file
# parses. Costs a full restore's time and disk. Worth it before a production migration.
# PROFILE_VERIFY_BACKUP_RESTORE=true

# Admin credentials — ONLY used by the `verify` subcommand, to exercise the Admin API after the
# migration (realms, clients, users, token issuance). Without them `verify` still checks the
# database and readiness, and tells you what it could not check.
# PROFILE_KC_ADMIN_USER=admin
# PROFILE_KC_ADMIN_PASSWORD=change-me

# Container runtime: docker | podman. Autodetected when unset.
# CONTAINER_RUNTIME=docker
